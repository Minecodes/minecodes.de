---
import ContentSection from "~/components/content-section.astro";
import { Icon } from "astro-icon";

const features = [
  {
    title: "randomfox",
    description:
      "This library gives back an random fox picture link or when you like it an custom message/link. It's coded in Typescript and can be used in Javascript and Typescript.",
    icon: "mdi:camera",
  },
  {
    title: "IMP",
    description: "This is a list of examples of my IMP classes.",
    icon: "mdi:book",
  },
  {
    title: "ps-logger",
    description:
      "ps-logger is a production grade logger, basically it is used for logging info,warning,error,silly,verbose,prompt and debug statements.",
    icon: "mdi:directions-fork",
  },
  {
    title: "caddy-jailbait",
    description: "It's just a simple redirect to the Jailbait Meme Sound.",
    icon: "mdi:web",
  },
  {
    title: "WhatLib",
    description:
      "An multi function library for challenges and for coders that love to explore the weird options of NodeJS",
    icon: "mdi:verified",
  },
  {
    title: "jsonDB",
    description:
      "An simple database created with Typescript and a single JSON file",
    icon: "mdi:view-list",
  },
];
---

<ContentSection title="$ ls projects" id="features">
  <Fragment slot="lead">
    All of these projects are published on <span class="text-primary"
      >Github
    </span>. They're published under <span class="text-primary">Minecodes</span>
    and <span class="text-primary">Tasudo</span>. Only <span
      class="text-primary"
      >ps-logger
    </span> is published under <span class="text-primary"
      >thisisshivanshpatel
    </span>.
  </Fragment>
  <ul class="grid max-w-6xl grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map(({ title, description, icon }) => (
        <li class="flex flex-col items-center gap-4 p-6 border border-default bg-offset">
          <div class="w-16 h-16 p-3 border-2 border-current rounded-full">
            <Icon name={icon} />
          </div>
          <p class="text-xl font-extrabold text-center">{title}</p>
          <p class="text-sm text-center text-offset">{description}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>
