---
import { Icon } from "astro-icon";
import HeroImage from "~/components/hero-image.astro";

const links = [
  {
    url: "https://youtube.com/Minecodes",
    description: "Minecodes on YouTube",
    icon: "mdi:youtube",
  },
  {
    url: "https://github.com/Minecodes",
    description: "Minecodes on GitHub",
    icon: "fa-brands:github-alt",
  },
  {
    url: "https://discord.gg/ngZaGzPnmq",
    description: "CodeLuna on Discord",
    icon: "fa-brands:discord",
  },
  {
    url: "https://twitter.com/minecodes_",
    description: "Minecodes on Twitter",
    icon: "fa-brands:twitter",
  },
];
---

<footer class="relative flex items-center justify-center h-64">
  <ul class="relative grid grid-cols-2 gap-4 sm:grid-cols-4">
    {
      links.map((link) => (
        <li>
          <a
            class="flex items-center justify-center w-16 h-16 p-4 border-2 border-current rounded-full"
            href={link.url}
          >
            <span class="sr-only">{link.description}</span>
            <Icon class="h-full" name={link.icon} />
          </a>
        </li>
      ))
    }
  </ul>
</footer>
